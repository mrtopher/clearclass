# ClearClass environment contract.
# Copy to `.env.local` for local dev and set the same vars in the Insforge
# deployment env. Only THIS file is committed; `.env.local` is gitignored.
#
# KTD11: model/search/rerank keys are SERVER-ONLY (no NEXT_PUBLIC_ prefix).
# The only client-safe Insforge value ClearClass needs is the base URL; any
# client anon key would also be NEXT_PUBLIC_ (never the admin key).

# ── Insforge backend (KTD2) — client-safe ────────────────────────────────
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-project.us-east.insforge.app
# OPTIONAL — Insforge's anonKey is optional and ClearClass does NOT use one: it
# exposes no anon-readable data (every table sits behind a user JWT or the admin
# key), so client calls authenticate with the logged-in user's token. Leave unset
# unless you add genuinely public/unauthenticated data endpoints.
# NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key

# Project ADMIN API key — SERVER-ONLY. Used by the offline corpus load
# (scripts/embed-load.ts, U4) to insert shared reference rows past RLS. Never
# expose with a NEXT_PUBLIC_ prefix. If unset, embed-load falls back to the
# `api_key` in .insforge/project.json for local dev.
# INSFORGE_API_KEY=ik_...

# ── LLM gateway (KTD9, R10) — SERVER-ONLY ─────────────────────────────────
# `npx @insforge/cli ai setup` writes OPENROUTER_API_KEY here (OpenRouter-backed
# gateway). lib/llm.ts uses it by default at https://openrouter.ai/api/v1.
# Model ids use OpenRouter "vendor/model" form.
OPENROUTER_API_KEY=provisioned-by-insforge-ai-setup
LLM_MODEL=openai/gpt-4o-mini
# Optional override to swap providers (e.g. Vercel AI Gateway) — takes precedence:
# LLM_BASE_URL=
# LLM_API_KEY=

# ── Retrieval augmentation (wired up in later units) — SERVER-ONLY ────────
# TAVILY_API_KEY=          # web-search tool (R3, U6)
# COHERE_API_KEY=          # rerank cross-encoder (U9)

# ── Observability (Task 2 monitoring) — SERVER-ONLY ───────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASEURL=https://cloud.langfuse.com

# ── Rate limiting (U11) — SERVER-ONLY ─────────────────────────────────────
# App-layer guard on the billable /api/chat path (middleware.ts). Fixed window,
# keyed per session (else per IP). Enforced PER INSTANCE — on a multi-instance
# deploy the effective ceiling is MAX × instances, so this is defense in depth,
# NOT the hard cost cap.
# RATE_LIMIT_MAX=30            # requests per window per key
# RATE_LIMIT_WINDOW_MS=60000   # window length in ms

# ── Spend caps (U11 backstop) — set in each provider's dashboard, NOT here ─
# The authoritative cross-instance cost backstop is a hard spend cap / budget
# alert on each server-only key below, configured in the provider console:
#   • LLM gateway (OpenRouter / Vercel AI Gateway) — monthly credit limit
#   • Tavily — free tier is 1,000 credits/mo; set an alert before it
#   • Cohere Rerank — trial/production key spend limit
# These bound cost even if the in-process rate limiter is bypassed by scale-out.
