# ClearClass environment contract.
# Copy to `.env.local` for local dev and set the same vars in the Insforge
# deployment env. Only THIS file is committed; `.env.local` is gitignored.
#
# KTD11: model/search/rerank keys are SERVER-ONLY (no NEXT_PUBLIC_ prefix).
# The Insforge anonKey is the ONLY credential permitted in client code.

# ── Insforge backend (KTD2) — client-safe ────────────────────────────────
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-project.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key

# ── LLM gateway (KTD9, R10) — SERVER-ONLY ─────────────────────────────────
# Insforge model gateway is OpenAI-compatible and OpenRouter-backed:
#   base URL ends in /v1, model ids use OpenRouter "vendor/model" form.
# Swap LLM_BASE_URL for Vercel AI Gateway / OpenRouter direct without code changes.
LLM_BASE_URL=https://your-project.insforge.dev/v1
LLM_API_KEY=your-insforge-provisioned-openrouter-key
LLM_MODEL=openai/gpt-4o-mini

# ── Retrieval augmentation (wired up in later units) — SERVER-ONLY ────────
# TAVILY_API_KEY=          # web-search tool (R3, U6)
# COHERE_API_KEY=          # rerank cross-encoder (U9)

# ── Observability (Task 2 monitoring) — SERVER-ONLY ───────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASEURL=https://cloud.langfuse.com
