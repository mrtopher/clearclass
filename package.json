{
  "name": "clearclass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:hts": "tsx scripts/ingest-hts.ts",
    "ingest:gri": "tsx scripts/ingest-gri.ts",
    "ingest:rulings": "tsx scripts/ingest-rulings.ts",
    "ingest": "npm run ingest:hts && npm run ingest:gri && npm run ingest:rulings",
    "migrate": "npx @insforge/cli db migrations up --all",
    "embed:load": "tsx --env-file-if-exists=.env.local scripts/embed-load.ts",
    "eval:recall": "tsx --env-file-if-exists=.env.local eval/retrieval-recall.ts",
    "eval": "tsx --env-file-if-exists=.env.local eval/run.ts",
    "verify:rls": "tsx --env-file-if-exists=.env.local scripts/verify-rls.ts",
    "seed:demo": "tsx --env-file-if-exists=.env.local scripts/seed-demo-broker.ts",
    "deploy": "npx @insforge/cli deployments deploy ."
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@insforge/sdk": "^1.4.3",
    "@langfuse/otel": "^5.9.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "ai": "^5.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoevals": "^0.0.132",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
